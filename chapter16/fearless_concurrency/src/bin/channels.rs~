use std::sync::mpsc;
use std::thread;
use std::time::Duration;

fn main(){
	let (tx, rx) = mpsc::channel();
	let v = vec![
		String::from("How"),
		String::from("High"),
		String::from("are"),
		String::from("you")
	];

	let tx1 = tx.clone();
	thread::spawn(move || {
		for val in v {
			tx1.send(val).unwrap();
			thread::sleep(Duration::from_secs(1));
		}
	});
	thread::spawn(move || {
		let val = String::from("Hi");
		tx.send(val).unwrap();
	});
	
	let received = rx.recv().unwrap();
	println!("received: {received}");
}
